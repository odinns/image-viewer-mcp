{
  "name": "image-viewer-mcp",
  "version": "1.0.0",
  "description": "MCP server for viewing images",
  "main": "image-viewer-mcp.js",
  "type": "module",
  "scripts": {
    "start": "node image-viewer-mcp.js",
    "dev": "node --watch image-viewer-mcp.js",
    "install-global": "npm install -g .",
    "lint": "eslint *.js",
    "lint:fix": "eslint *.js --fix",
    "format": "prettier --write *.js *.json *.md",
    "format:check": "prettier --check *.js *.json *.md"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "image",
    "analysis",
    "dusk",
    "testing",
    "screenshots"
  ],
  "author": "Worksome Platform Team",
  "license": "MIT",
  "bin": {
    "image-mcp-server": "./image-mcp-server.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.35.1"
  }
}
